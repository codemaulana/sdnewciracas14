generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String?
  role      String?
}

model Articles {
  id        String   @id @default(cuid())
  judul     String
  image     String
  author    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  kategori  String?
  viewCount Int      @default(0)
}

model Pdf {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  file      String
  title     String
}

model Galeri {
  id        String   @id @default(cuid())
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
